# ═══════════════════════════════════════════
# AI JOB FINDER AGENT - Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env and fill in your values

# ── AI APIs ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── MongoDB Atlas ────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/job-finder-agent?retryWrites=true&w=majority

# ── Email (Gmail SMTP) ──────────────────
# You need a Gmail App Password, NOT your regular password
# Go to: Google Account → Security → 2FA → App Passwords
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
RECIPIENT_EMAIL=your.email@gmail.com

# ── WhatsApp (Twilio) ───────────────────
# Sign up at twilio.com, get sandbox WhatsApp number
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
RECIPIENT_WHATSAPP=whatsapp:+91XXXXXXXXXX

# ── Scraping APIs (optional fallback) ───
SCRAPINGBEE_API_KEY=
SCRAPEOPS_API_KEY=

# ── Job Search Configuration ────────────
JOB_ROLES="Software Engineer, Frontend Developer, Full Stack Developer, React Developer"
JOB_LOCATION="India, Remote"
EXPERIENCE_YEARS=3
MIN_MATCH_SCORE=60
MAX_JOBS_PER_DAY=30

# ── Resume ──────────────────────────────
RESUME_PATH=./resume/my_resume.pdf
PORTFOLIO_URL=https://yourportfolio.com
