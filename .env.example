# ═══════════════════════════════════════════
# AI JOB FINDER AGENT - Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env and fill in your values

# ── AI APIs ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── MongoDB Atlas ────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/job-finder-agent?retryWrites=true&w=majority

# ── Email (Gmail SMTP) ──────────────────
# You need a Gmail App Password, NOT your regular password
# Go to: Google Account → Security → 2FA → App Passwords
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
RECIPIENT_EMAIL=your.email@gmail.com

# ── WhatsApp (Twilio) ───────────────────
# Sign up at twilio.com, get sandbox WhatsApp number
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
RECIPIENT_WHATSAPP=whatsapp:+91XXXXXXXXXX

# ── Scraping APIs (optional fallback) ───
SCRAPINGBEE_API_KEY=
SCRAPEOPS_API_KEY=

# ── AI/LLM job -> Google Sheet pipeline (independent daily job) ──
# Apify API token (Apify Console -> Settings -> Integrations)
APIFY_TOKEN=apify_api_xxxxx
# Google service-account key. Either paste the whole JSON on ONE line here...
GOOGLE_SA_JSON={"type":"service_account","project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}
# ...or, for local dev, point to a key file instead (GOOGLE_SA_JSON takes precedence):
# GOOGLE_SA_JSON_PATH=./secrets/sheet-sa.json
# Target spreadsheet ID (share it with the service account's client_email as Editor)
JOB_SHEET_ID=1Pht8ULtIbQQiSmi7oizuGC3MYMU8WV79chBYoEK5D-U

# ── Job Search Configuration ────────────
JOB_ROLES="AI Engineer, LLM Engineer, GenAI Engineer, Backend Developer, Software Engineer, Full Stack Developer"
JOB_LOCATION="India, Remote"
EXPERIENCE_YEARS=3
MIN_MATCH_SCORE=65
MAX_JOBS_PER_DAY=30

# ── Resume ──────────────────────────────
RESUME_PATH=./resume/my_resume.pdf
PORTFOLIO_URL=https://yourportfolio.com
