# AWS Lambda container image for Job Finder Agent
# Uses custom Node.js image with Chromium + Lambda Runtime Interface Client
FROM node:20-slim

# Install chromium + build tools for aws-lambda-ric native compilation
RUN apt-get update && apt-get install -y \
    chromium \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnss3 \
    libx11-xcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    xdg-utils \
    python3 \
    make \
    g++ \
    --no-install-recommends \
    && rm -rf /var/lib/apt/lists/*

ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev
RUN npm install aws-lambda-ric

COPY . .

RUN mkdir -p logs resume

ENTRYPOINT ["/usr/local/bin/npx", "aws-lambda-ric"]
CMD ["lambda.handler"]
